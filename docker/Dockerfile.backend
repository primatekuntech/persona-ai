FROM rust:1.80-slim AS builder

RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Cache dependencies
COPY backend/Cargo.toml backend/Cargo.lock* ./backend/
RUN mkdir -p backend/src && echo "fn main(){}" > backend/src/main.rs
# Create placeholder assets so the build can resolve include_str! at dependency-cache stage
RUN mkdir -p backend/assets && \
    touch backend/assets/common-passwords.txt && \
    printf '[llm]\n' > backend/assets/models.toml
RUN cd backend && cargo build --release 2>/dev/null; exit 0

# Full build
COPY backend ./backend
RUN cd backend && cargo build --release

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /build/backend/target/release/persona-ai /app/persona-ai

RUN useradd -m -u 1001 persona
USER persona

EXPOSE 8080
ENTRYPOINT ["/app/persona-ai"]
