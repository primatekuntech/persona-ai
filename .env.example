# Copy to .env and fill in values before running locally.
# In production, set these as real environment variables (not a .env file).

# Required
DATABASE_URL=postgres://persona:secret@localhost:5432/persona_ai
SESSION_SECRET=<64 hex chars — generate with: openssl rand -hex 32>
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Persona AI <noreply@yourdomain.com>
APP_BASE_URL=http://localhost:5173

# Optional — admin bootstrap (creates an admin user on first start if no admin exists)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=<strong password, min 12 chars>

# Optional — development only
DEV_CORS=true
RUST_ENV=development
RUST_LOG=info,persona_ai=debug,sqlx=warn

# Optional — paths (defaults shown)
DATA_DIR=/data
MODEL_DIR=/data/models
